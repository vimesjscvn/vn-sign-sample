{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AppSettings": {
    "TerminalSetting": {
      "BaseUrl": "https://mpki2.ca.gov.vn/mpki/v2/",
      "RelyingParty": "[YOUR_RELYING_PARTY]",
      "RelyingPartyUser": "[YOUR_RELYING_PARTY_USER]",
      "RelyingPartyPassword": "[YOUR_RELYING_PARTY_PASSWORD]",
      "RelyingPartySignature": "[YOUR_RELYING_PARTY_SIGNATURE]",
      "RelyingPartyKeyStore": "[YOUR_KEYSTORE_FILE_NAME].p12",
      "RelyingPartyKeyStorePassword": "[YOUR_KEYSTORE_PASSWORD]",
      "SignAlgorithm": "ECDSA"
    },
    "InternalSetting": {
      "HospitalName": "BỆNH VIỆN",
      "CompanyName": "VIMES., JSC",
      "DefaultMerchantId": "VIETTEL",
      "SignatureMode": 0,
      "IsEnableRegisterExtension": true,
      "IsAllowAutoSign": true,
      "NumSignatures": 500,
      "SearchBySignerName": 0,
      "ShowSignatureImage": 1,
      "IsEnableStoreData": false
    },
    "FileStorageSetting": {
      "WebRootFallback": "wwwroot",
      "ExportFolderName": "export",
      "CertsFolderName": "certs",
      "OverwriteAllowed": true,
      "MaxFileSizeMB": 64
    },
    "MySignSetting": {
      "BaseUrl": "https://remotesigning.viettel.vn",
      "ProfileId": "adss:ras:profile:008",
      "ClientId": "[YOUR_MYSIGN_CLIENT_ID]",
      "ClientSecret": "[YOUR_MYSIGN_CLIENT_SECRET]"
    },
    "SmartCASetting": {
      "BaseUrl": "https://gwsca.vnpt.vn",
      "ProfileId": "adss:ras:profile:001",
      "ClientId": "[YOUR_SMARTCA_CLIENT_ID]",
      "ClientSecret": "[YOUR_SMARTCA_CLIENT_SECRET]"
    },
    "CacheSetting": {
      "Backend": "Memory",
      "AbsoluteMinutes": 720
    },
    "MsspSetting": {
      "CertFolderName": "certs",
      "CertFileName": "[YOUR_PROVIDER_CERTIFICATE].pfx",
      "CertPassword": "[YOUR_PFX_PASSWORD]",
      "CertCacheMinutes": 1440,
      "ApId": "[YOUR_AP_ID]",
      "ApPassword": "[YOUR_AP_PASSWORD]",
      "MsspId": "http://hmssp.mobile-id.vn",
      "SignatureProfile": "http://mobile-id.vn/digitalSignature",
      "MssFormat": "http://uri.etsi.org/TS102204/v1.1.2#PKCS1",
      "SigningCertService": "http://mobile-id.vn/MSSP/v1.0.0#signingCertificate",
      "SignatureValidationService": "http://mobile-id.vn/MSSP/v1.0.0#signatureValidation"
    },
    "UsbSetting": {
      "UsbAgentIp": "127.0.0.1",
      "UsbAgentPort": 9999,
      "UsbTokenPin": "[YOUR_USB_PIN]"
    }
  }
}
