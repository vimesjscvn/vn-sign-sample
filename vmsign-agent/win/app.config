<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="Port"                   value="9999"/>
    <add key="DiscoveryPort"          value="9998"/>
    <!-- Optional: preset PIN for unattended signing (no interactive dialog).
         Leave blank to keep the token's normal PIN prompt. -->
    <add key="Token:Pin"              value=""/>
    <add key="Token:SelectedCertificateSerial" value=""/>
    <add key="Ui:ShowSignSuccessToast" value="true"/>
    <!-- End-user phone number. SignSDK USB API uses user_name = this phone number and password = Token:Pin. -->
    <add key="EndUser:PhoneNumber"    value=""/>
    <!-- Optional: override PKCS#11 module path (default: C:\Windows\System32\bit4xpki.dll) -->
    <add key="Token:Pkcs11Module"     value=""/>
    <!-- MQTT: leave BrokerHost blank to disable MQTT (local HTTP only) -->
    <add key="Mqtt:BrokerHost"        value="108.108.108.251"/>
    <add key="Mqtt:BrokerPort"        value="1883"/>
    <add key="Mqtt:Username"          value=""/>
    <add key="Mqtt:Password"          value=""/>
    <add key="Mqtt:UseTls"            value="false"/>
    <add key="Mqtt:AgentId"           value=""/>
    <add key="Mqtt:CaCertPath"        value=""/>
    <add key="Mqtt:ClientPfxPath"     value=""/>
    <add key="Mqtt:ClientPfxPassword" value=""/>
    <add key="Mqtt:AllowUntrusted"    value="false"/>
  </appSettings>
</configuration>
